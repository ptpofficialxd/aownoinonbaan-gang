# Session signing secret. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Neon Postgres connection string
DATABASE_URL=

# Google OAuth client used for one-time owner authorization
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Exact callback URL configured in Google Cloud OAuth client
# Example: http://localhost:3000/api/google-drive/oauth/callback
GOOGLE_OAUTH_REDIRECT_URI=

# Root folder that will contain all gang uploads
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Optional: app brand contact shown on login screen
NEXT_PUBLIC_CONTACT_HANDLE=

# Optional: upload limit in MB, defaults to 250
MAX_UPLOAD_SIZE_MB=250
