# Session signing secret. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Neon Postgres connection string
DATABASE_URL=

# Google service account used to upload and read files in Drive
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Root folder that will contain all gang uploads
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Optional: if you upload into a Shared Drive, set its id here
GOOGLE_DRIVE_SHARED_DRIVE_ID=

# Optional: app brand contact shown on login screen
NEXT_PUBLIC_CONTACT_HANDLE=@aownoinonbaan

# Optional: upload limit in MB, defaults to 250
MAX_UPLOAD_SIZE_MB=250
